<Window x:Class="SSHClient.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:coreModels="clr-namespace:SSHClient.Core.Models;assembly=SSHClient.Core"
        mc:Ignorable="d"
        Title="SSH Client"
        Width="600"
        Height="600"
        MinWidth="600"
        MinHeight="600"
        FontSize="11"
        WindowStartupLocation="CenterScreen"
        Background="#E6E9EF">
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,2,6,2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,2,6,2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,2,8,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,2,8,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,2,8,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 上：当前 profile + 小图标切换（透明背景） -->
        <Border Grid.Row="0" Background="Transparent" BorderThickness="0" Padding="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Current profile:" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding ProfilesVM.SelectedProfile.Name, TargetNullValue=Default}" FontWeight="Bold" Foreground="#1D4ED8"/>
            </StackPanel>
        </Border>

        <!-- 中：Tab + Action Buttons -->
        <Border Grid.Row="1" Margin="0,4,0,6" Background="#FFFFFF" BorderBrush="#D2D8E2" BorderThickness="1" CornerRadius="3" Padding="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 中上：Tab -->
                <TabControl Grid.Row="0" Margin="0,0,0,6" VerticalAlignment="Stretch">
                    <TabItem Header="Login">
                        <Grid Margin="4" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <GroupBox Header="Server" Grid.Column="0" Margin="0,0,6,0" VerticalAlignment="Top">
                                    <Grid Margin="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Host" Grid.Row="0" Grid.Column="0"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.Host, Mode=TwoWay}"/>
                                        <TextBlock Text="Port" Grid.Row="1" Grid.Column="0"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.Port, Mode=TwoWay}"/>
                                        <TextBlock Text="Listen address" Grid.Row="2" Grid.Column="0"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.LocalListenAddress, Mode=TwoWay}"/>
                                        <TextBlock Text="Listen port" Grid.Row="3" Grid.Column="0"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.LocalSocksPort, Mode=TwoWay}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Authentication" Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Top">
                                    <Grid Margin="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="85"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Username" Grid.Row="0" Grid.Column="0"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.Username, Mode=TwoWay}"/>
                                        <TextBlock Text="Method" Grid.Row="1" Grid.Column="0"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1"
                                                  SelectedValuePath="Tag"
                                                  SelectedValue="{Binding ProfilesVM.SelectedProfile.AuthMethod, Mode=TwoWay}">
                                            <ComboBoxItem Content="Password" Tag="{x:Static coreModels:SshAuthMethod.Password}"/>
                                        </ComboBox>
                                        <TextBlock Text="Password" Grid.Row="2" Grid.Column="0"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </GroupBox>
                            </Grid>

                            <Border Grid.Row="1" Margin="0,8,0,0" BorderBrush="#D2D8E2" BorderThickness="1" Background="#FCFDFF">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Log" FontWeight="SemiBold" Margin="8,6"/>
                                    <TextBox Grid.Row="1"
                                             Name="LiveLogTextBox"
                                             Margin="6,0,6,6"
                                             Text="{Binding LiveLog, Mode=OneWay}"
                                             Height="Auto"
                                             VerticalAlignment="Stretch"
                                             VerticalContentAlignment="Top"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             IsReadOnly="True"
                                             TextChanged="LogTextBox_TextChanged"
                                             BorderThickness="1"
                                             BorderBrush="#D2D8E2"
                                             FontFamily="Consolas"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="About">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#D2D8E2" BorderThickness="1" CornerRadius="3" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="SSH Client" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="A compact SSH proxy client for Windows" Margin="0,3,0,0" Foreground="#475569"/>
                                    <TextBlock Text="Runtime: .NET 8 / UI: WPF" Margin="0,4,0,0" Foreground="#64748B"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Margin="0,8,0,0" Background="#FFFFFF" BorderBrush="#D2D8E2" BorderThickness="1" CornerRadius="3" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Platform" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Windows"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Transport" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="SSH Tunnel + Local Proxy"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Config" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Profiles and rules saved locally"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Margin="0,8,0,0" Background="#FFFFFF" BorderBrush="#D2D8E2" BorderThickness="1" CornerRadius="3" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Quick notes" FontWeight="SemiBold"/>
                                    <TextBlock Text="- Use Save to persist profile changes" Margin="0,4,0,0"/>
                                    <TextBlock Text="- Use Load to reload profiles from config" Margin="0,2,0,0"/>
                                    <TextBlock Text="- Log panel supports text selection and copy" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>

                <!-- 中底：Action 按钮 -->
                <UniformGrid Grid.Row="1" Margin="0,8,0,0" Columns="4" HorizontalAlignment="Stretch">
                    <Button Content="Log in"
                        Width="90"
                        Command="{Binding ProfilesVM.ConnectCommand}"
                        Style="{StaticResource PrimaryButton}"/>
                    <Button Content="Save"
                        Width="90"
                        Command="{Binding ProfilesVM.SaveProfileCommand}"
                        Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Load"
                        Width="90"
                        Command="{Binding ProfilesVM.RefreshCommand}"
                        Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Exit"
                        Width="90"
                        Style="{StaticResource SecondaryButton}"
                        Click="ExitButton_Click"/>
                </UniformGrid>
            </Grid>
        </Border>

        <!-- 下：版权信息（透明背景、低高度、小字号） -->
        <Border Grid.Row="2" Background="Transparent" BorderThickness="0" Padding="0,2,0,0">
            <TextBlock Text="Copyright (C) 2026 SSH Client. All rights reserved."
                       FontSize="9"
                       HorizontalAlignment="Center"
                       Foreground="#64748B"/>
        </Border>
    </Grid>
</Window>
