<Window x:Class="SSHClient.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:coreModels="clr-namespace:SSHClient.Core.Models;assembly=SSHClient.Core"
        xmlns:converters="clr-namespace:SSHClient.App.Converters"
        xmlns:controls="clr-namespace:SSHClient.App.Controls"
        mc:Ignorable="d"
        Title="SSH 客户端"
        Icon="Assets/app.ico"
        Width="600"
        Height="600"
        MinWidth="600"
        MinHeight="600"
        FontSize="11"
        WindowStartupLocation="CenterScreen"
        Background="#E6E9EF">
    <Window.Resources>
        <converters:RuleActionDisplayConverter x:Key="RuleActionDisplayConverter"/>
        <converters:RuleTypeDisplayConverter x:Key="RuleTypeDisplayConverter"/>
        <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,2,6,2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                                <Trigger Property="Tag" Value="登出">
                                    <Setter TargetName="Bd" Property="Background" Value="#DC2626"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="Tag" Value="登出"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="#B91C1C"/>
                                </MultiTrigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="Tag" Value="登出"/>
                                        <Condition Property="IsPressed" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="#991B1B"/>
                                </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,2,6,2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,2,8,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,2,8,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 上：当前 profile + 小图标切换（透明背景） -->
        <Border Grid.Row="0" Background="Transparent" BorderThickness="0" Padding="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="当前配置：" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ProfilesVM.SelectedProfile.Name, TargetNullValue=默认}" FontWeight="Bold" Foreground="#1D4ED8"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Name="MinimizeBehaviorButton"
                        Width="28"
                        Height="24"
                        Margin="0,0,0,0"
                        Padding="0"
                        ToolTip="最小化行为"
                        Style="{StaticResource SecondaryButton}"
                        Click="MinimizeBehaviorButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu Name="MinimizeBehaviorContextMenu">
                            <MenuItem Name="TaskbarMinimizeMenuItem" Header="仅最小化" Click="TaskbarMinimizeMenuItem_Click"/>
                            <MenuItem Name="TrayMinimizeMenuItem" Header="最小化到托盘" Click="TrayMinimizeMenuItem_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE712;" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <!-- 中：Tab + Action Buttons -->
        <Border Grid.Row="1" Margin="0,4,0,6" Background="#FFFFFF" BorderBrush="#D2D8E2" BorderThickness="1" CornerRadius="3" Padding="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 中上：Tab -->
                <TabControl Grid.Row="0" Margin="0,0,0,6" VerticalAlignment="Stretch">
                    <TabItem Header="登录">
                        <Grid Margin="4" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <GroupBox Header="服务器" Grid.Column="0" Margin="0,0,6,0" VerticalAlignment="Top">
                                    <Grid Margin="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="主机" Grid.Row="0" Grid.Column="0"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.Host, Mode=TwoWay}"/>
                                        <TextBlock Text="端口" Grid.Row="1" Grid.Column="0"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.Port, Mode=TwoWay}"/>
                                        <TextBlock Text="监听地址" Grid.Row="2" Grid.Column="0"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.LocalListenAddress, Mode=TwoWay}"/>
                                        <TextBlock Text="监听端口" Grid.Row="3" Grid.Column="0"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.LocalSocksPort, Mode=TwoWay}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="认证" Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Top">
                                    <StackPanel Margin="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="用户名" Grid.Column="0"/>
                                            <TextBox Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.Username, Mode=TwoWay}"/>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="方式" Grid.Column="0"/>
                                            <ComboBox Grid.Column="1"
                                                      SelectedValuePath="Tag"
                                                      SelectedValue="{Binding ProfilesVM.SelectedProfile.AuthMethod, Mode=TwoWay}">
                                                <ComboBoxItem Content="密码" Tag="{x:Static coreModels:SshAuthMethod.Password}"/>
                                                <ComboBoxItem Content="公钥" Tag="{x:Static coreModels:SshAuthMethod.PrivateKey}"/>
                                            </ComboBox>
                                        </Grid>

                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProfilesVM.SelectedProfile.AuthMethod}" Value="{x:Static coreModels:SshAuthMethod.Password}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="密码" Grid.Column="0"/>
                                            <TextBox Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>

                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProfilesVM.SelectedProfile.AuthMethod}" Value="{x:Static coreModels:SshAuthMethod.PrivateKey}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="密钥文件" Grid.Row="0" Grid.Column="0"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.PrivateKeyPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBlock Text="密钥口令" Grid.Row="1" Grid.Column="0"/>
                                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProfilesVM.SelectedProfile.PrivateKeyPassphrase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>
                            </Grid>

                            <Border Grid.Row="1" Margin="0,8,0,0" BorderBrush="#D2D8E2" BorderThickness="1" Background="#FCFDFF">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="日志" FontWeight="SemiBold" Margin="8,6"/>
                                    <TextBox Grid.Row="1"
                                             Name="LiveLogTextBox"
                                             Margin="6,0,6,6"
                                             Text="{Binding LiveLog, Mode=OneWay}"
                                             Height="Auto"
                                             VerticalAlignment="Stretch"
                                             VerticalContentAlignment="Top"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             IsReadOnly="True"
                                             TextChanged="LogTextBox_TextChanged"
                                             BorderThickness="1"
                                             BorderBrush="#D2D8E2"
                                             FontFamily="Consolas"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto">
                                        <TextBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="复制" Command="ApplicationCommands.Copy"/>
                                                <MenuItem Header="全选" Command="ApplicationCommands.SelectAll"/>
                                                <Separator/>
                                                <MenuItem Header="清理日志" Command="{Binding ClearLogCommand}"/>
                                            </ContextMenu>
                                        </TextBox.ContextMenu>
                                    </TextBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="规则">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="新增规则"
                                        Width="90"
                                        Click="AddRuleButton_Click"
                                        Style="{StaticResource SecondaryButton}"/>
                                <Button Content="编辑规则"
                                    Width="90"
                                    Click="EditRuleButton_Click"
                                    Style="{StaticResource SecondaryButton}"/>
                                <Button Content="删除规则"
                                        Width="90"
                                        Command="{Binding ProfilesVM.DeleteRuleCommand}"
                                        Style="{StaticResource SecondaryButton}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1"
                                       Margin="2,0,0,8"
                                       Foreground="#64748B"
                                       Text="说明：新增/编辑规则通过弹窗录入；类型支持 全部/域名/IP 段。域名可输入多条（; 或换行分隔），IP 段使用 CIDR；选择全部时无需输入。列表中仅可修改动作。"/>

                            <DataGrid Grid.Row="2"
                                      Name="RulesDataGrid"
                                      ItemsSource="{Binding ProfilesVM.Rules}"
                                      SelectedItem="{Binding ProfilesVM.SelectedRule, Mode=TwoWay}"
                                      MouseDoubleClick="RulesDataGrid_MouseDoubleClick"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      RowHeight="30"
                                      BorderBrush="#D2D8E2"
                                      BorderThickness="1">
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="6,0,6,0"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="名称" Width="120" Binding="{Binding Name}" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="优先级" Width="80" Binding="{Binding Priority}" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="匹配" Width="*" Binding="{Binding Pattern}" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="类型" Width="120" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Type, Converter={StaticResource RuleTypeDisplayConverter}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="动作" Width="90" IsReadOnly="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Height="24"
                                                          VerticalAlignment="Center"
                                                          ItemsSource="{Binding DataContext.ProfilesVM.RuleActions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding Action, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource RuleActionDisplayConverter}}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="监控">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="130"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 速率标签 -->
                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Width="10" Height="10" Background="#22C55E" CornerRadius="2" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="上行" Foreground="#64748B" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding MonitorVM.CurrentUp}" FontWeight="SemiBold" Foreground="#22C55E"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Width="10" Height="10" Background="#3B82F6" CornerRadius="2" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="下行" Foreground="#64748B" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding MonitorVM.CurrentDown}" FontWeight="SemiBold" Foreground="#3B82F6"/>
                                </StackPanel>
                            </Grid>

                            <!-- 折线图 -->
                            <controls:SparklineChart
                                Grid.Row="1"
                                UpSeries="{Binding MonitorVM.UpHistory}"
                                DownSeries="{Binding MonitorVM.DownHistory}"
                                UpColor="#22C55E"
                                DownColor="#3B82F6"
                                GridLineCount="4"/>

                            <!-- 连接列表标题 -->
                            <TextBlock Grid.Row="2" Text="连接详情" FontWeight="SemiBold" Margin="0,8,0,4"/>

                            <!-- 连接列表 -->
                            <DataGrid Grid.Row="3"
                                      Name="MonitorConnectionsDataGrid"
                                      ItemsSource="{Binding MonitorVM.Connections}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      RowHeight="26"
                                      BorderBrush="#D2D8E2"
                                      BorderThickness="1">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="复制当前地址" Click="MonitorCopyAddressMenuItem_Click"/>
                                        <Separator/>
                                        <MenuItem Header="清空监控数据" Click="MonitorClearDataMenuItem_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="4,0"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="22" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Ellipse Width="8" Height="8"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                                         Fill="{Binding RouteColor, Converter={StaticResource StringToBrushConverter}}"
                                                         ToolTip="{Binding RouteLabel}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="地址" Width="*" Binding="{Binding HostPort}"/>
                                    <DataGridTextColumn Header="连接时间" Width="70" Binding="{Binding ConnectedAt}"/>
                                    <DataGridTextColumn Header="上行" Width="90" Binding="{Binding UpRate}"/>
                                    <DataGridTextColumn Header="下行" Width="90" Binding="{Binding DownRate}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="关于">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#D2D8E2" BorderThickness="1" CornerRadius="3" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="SSH 客户端" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="面向 Windows 的轻量 SSH 代理客户端" Margin="0,3,0,0" Foreground="#475569"/>
                                    <TextBlock Text="运行时：.NET 8 / 界面：WPF" Margin="0,4,0,0" Foreground="#64748B"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Margin="0,8,0,0" Background="#FFFFFF" BorderBrush="#D2D8E2" BorderThickness="1" CornerRadius="3" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="平台" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Windows"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="传输" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="SSH 隧道 + 本地代理"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="配置" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="配置与规则本地保存"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Margin="0,8,0,0" Background="#FFFFFF" BorderBrush="#D2D8E2" BorderThickness="1" CornerRadius="3" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="快速说明" FontWeight="SemiBold"/>
                                    <TextBlock Text="- 使用 保存 持久化当前配置" Margin="0,4,0,0"/>
                                    <TextBlock Text="- 使用 另存为 导出当前配置文件" Margin="0,2,0,0"/>
                                    <TextBlock Text="- 使用 读取 可从任意目录加载配置文件" Margin="0,2,0,0"/>
                                    <TextBlock Text="- 日志面板支持文本选择与复制" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>

                <!-- 中底：Action 按钮 -->
                <UniformGrid Grid.Row="1" Margin="0,8,0,0" Columns="5" HorizontalAlignment="Stretch">
                    <Button Content="{Binding ProfilesVM.ConnectButtonText}"
                        Width="90"
                        Tag="{Binding ProfilesVM.ConnectButtonText}"
                        Command="{Binding ProfilesVM.ConnectCommand}"
                        Style="{StaticResource PrimaryButton}"/>
                    <Button Content="保存"
                        Width="90"
                        Command="{Binding ProfilesVM.SaveProfileCommand}"
                        Style="{StaticResource SecondaryButton}"/>
                    <Button Content="另存为"
                        Width="90"
                        Style="{StaticResource SecondaryButton}"
                        Click="SaveAsButton_Click"/>
                    <Button Content="读取"
                        Width="90"
                        Click="LoadFromFileButton_Click"
                        Style="{StaticResource SecondaryButton}"/>
                    <Button Content="退出"
                        Width="90"
                        Style="{StaticResource SecondaryButton}"
                        Click="ExitButton_Click"/>
                </UniformGrid>
            </Grid>
        </Border>

        <!-- 下：版权信息（透明背景、低高度、小字号） -->
        <Border Grid.Row="2" Background="Transparent" BorderThickness="0" Padding="0,2,0,0">
            <TextBlock Text="版权所有 (C) 2026 SSH 客户端。保留所有权利。"
                       FontSize="9"
                       HorizontalAlignment="Center"
                       Foreground="#64748B"/>
        </Border>
    </Grid>
</Window>
