<Window x:Class="SSHClient.App.PacPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PAC 预览"
        Width="820"
        Height="620"
        MinWidth="640"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#E6E9EF">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,8"
                   FontWeight="SemiBold"
                   Text="当前规则生成的 PAC 脚本（仅代理规则进入脚本）"/>

        <TextBox Grid.Row="1"
                 Name="PacTextBox"
                 Text=""
                 FontFamily="Consolas"
                 FontSize="12"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 BorderBrush="#CBD5E1"
                 BorderThickness="1"/>

        <StackPanel Grid.Row="2"
                    Margin="0,10,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="80"
                    Height="28"
                    Margin="0,0,8,0"
                    Content="复制"
                    Click="CopyButton_Click"/>
            <Button Width="80"
                    Height="28"
                    Content="关闭"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
