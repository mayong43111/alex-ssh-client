<Window x:Class="SSHClient.App.RuleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:coreModels="clr-namespace:SSHClient.Core.Models;assembly=SSHClient.Core"
        Title="新增规则"
        SizeToContent="WidthAndHeight"
        MinWidth="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="名称"/>
        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" x:Name="RuleNameTextBox" Height="26"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="优先级"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" x:Name="RulePriorityTextBox" Height="26"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="类型"/>
        <ComboBox Grid.Row="2"
                  Grid.Column="1"
                  Margin="0,0,0,8"
                  x:Name="RuleTypeComboBox"
                  Height="26"
                  SelectedIndex="0"
                  SelectedValuePath="Tag">
            <ComboBoxItem Content="全部" Tag="All"/>
            <ComboBoxItem Content="域名" Tag="DomainSuffix"/>
            <ComboBoxItem Content="IP 段" Tag="IpCidr"/>
        </ComboBox>

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Top" Text="匹配"/>

        <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" x:Name="DomainInputGrid">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedValue, ElementName=RuleTypeComboBox}" Value="DomainSuffix">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Margin="0,0,0,4" Foreground="#64748B" Text="支持 * 通配符；多条可用 ; 或换行分隔"/>
            <TextBox Grid.Row="1"
                     x:Name="DomainPatternsTextBox"
                     MinHeight="88"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"/>
        </Grid>

        <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" x:Name="IpInputGrid">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedValue, ElementName=RuleTypeComboBox}" Value="IpCidr">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBox x:Name="IpAddressTextBox" Width="190" Height="26" Margin="0,0,4,0"/>
                <TextBlock Text="/" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="IpPrefixTextBox" Width="44" Height="26" Text="32"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" x:Name="AllInputGrid">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedValue, ElementName=RuleTypeComboBox}" Value="All">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <TextBlock Foreground="#64748B" VerticalAlignment="Center" Text="全部类型无需输入匹配内容"/>
        </Grid>

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="动作"/>
        <ComboBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" x:Name="RuleActionComboBox" Height="26" SelectedIndex="0">
            <ComboBoxItem Content="代理" Tag="{x:Static coreModels:RuleAction.Proxy}"/>
            <ComboBoxItem Content="直连" Tag="{x:Static coreModels:RuleAction.Direct}"/>
            <ComboBoxItem Content="拒绝" Tag="{x:Static coreModels:RuleAction.Reject}"/>
        </ComboBox>

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="取消" Width="84" Height="28" Margin="0,0,8,0" IsCancel="True" Click="CancelButton_Click"/>
            <Button Content="确定" Width="84" Height="28" IsDefault="True" Click="ConfirmButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
